# ============================================
# 1. ТОЧКА ВХОДА (ENTRYPOINT)
# ============================================
# Указывает главный файл, который будет запускаться при старте проекта
entrypoint = "main.py"

# ============================================
# 2. МОДУЛИ PYTHON
# ============================================
# Список модулей (версий Python), доступных в окружении
modules = ["python-3.11"]

# ============================================
# 3. НАСТРОЙКИ NIX (УПРАВЛЕНИЕ ПАКЕТАМИ)
# ============================================
# Блок с конфигурацией Nix (менеджер пакетов для Replit)

[nix]
# Канал (репозиторий) Nix для загрузки пакетов
channel = "stable-25_05"

# Пакеты, устанавливаемые в окружение:
packages = [
    "cairo",                 # 2D графика (используется matplotlib)
    "ffmpeg-full",          # обработка видео/аудио
    "freetype",             # рендеринг шрифтов (matplotlib)
    "ghostscript",          # работа с PostScript/PDF
    "glibcLocales",         # локализация (правильное отображение текста)
    "gobject-introspection", # работа с GTK-библиотеками
    "gtk3",                 # графический интерфейс (для отображения графиков)
    "pkg-config",           # поиск установленных библиотек
    "qhull",                # вычислительная геометрия (3D визуализация)
    "tcl",                  # скриптовый язык (используется matplotlib)
    "tk"                    # графическая библиотека (бэкенд matplotlib)
]

# ============================================
# 4. НАСТРОЙКИ ЮНИТ-ТЕСТИРОВАНИЯ
# ============================================
[unitTest]
language = "python3"   # Язык для модульного тестирования

# ============================================
# 5. НАСТРОЙКИ ИМПОРТА ИЗ GITHUB
# ============================================
[gitHubImport]
# Файлы, обязательные для импорта репозитория с GitHub
requiredFiles = [".replit", "replit.nix"]

# ============================================
# 6. НАСТРОЙКИ РАЗВЕРТЫВАНИЯ (DEPLOYMENT)
# ============================================
[deployment]
# Команда для запуска приложения
run = ["python3", "main.py"]

# Цель развертывания: cloudrun (облачный сервис Replit)
deploymentTarget = "cloudrun"

# ============================================
# 7. НАСТРОЙКИ AI-АГЕНТА
# ============================================
[agent]
# Включение экспертного режима для AI-помощника
expertMode = true